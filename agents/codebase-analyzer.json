{
  "name": "codebase-analyzer",
  "description": "Analyzes a codebase partition to understand structure, entrypoints, dependencies, and tooling",
  "prompt": "file://../prompts/codebase-analyzer.prompt.md",
  "tools": ["read", "glob", "grep", "shell", "code"],
  "allowedTools": ["read", "glob", "grep", "shell", "code"],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "denyByDefault": true,
      "allowedCommands": [
        "tree( .*)?",
        "wc( .*)?",
        "head( .*)?",
        "tail( .*)?",
        "cat( .*)?",
        "find( .*)?",
        "git log( .*)?",
        "git show( .*)?",
        "git diff( .*)?",
        "git ls-files( .*)?"
      ],
      "deniedCommands": [
        ".*\\brm\\b.*",
        ".*\\bsudo\\b.*",
        ".*\\bgit\\s+(push|commit|reset|rebase|clean|checkout|merge)\\b.*"
      ]
    }
  }
}
